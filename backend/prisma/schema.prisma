// Prisma schema file for TreckWari
// Supports both PostgreSQL and SQLite.
// To switch to PostgreSQL, change the provider to "postgresql" and update DATABASE_URL in .env.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Roles: SUPER_ADMIN, ADMIN, TREK_LEADER, VOLUNTEER, USER
model User {
  id                        String         @id @default(uuid())
  email                     String         @unique
  name                      String
  passwordHash              String
  phone                     String?        @unique
  role                      String         @default("USER") // SUPER_ADMIN, ADMIN, TREK_LEADER, VOLUNTEER, USER
  avatarUrl                 String?
  googleId                  String?
  referralCode              String         @unique
  referredBy                String?
  rewardPoints              Int            @default(0)
  badgeLevel                String         @default("BRONZE_EXPLORER") // BRONZE_EXPLORER, SILVER_ADVENTURER, GOLD_MOUNTAIN_WARRIOR, SUMMIT_LEGEND
  
  // Verification & Account status
  emailVerified             Boolean        @default(false)
  emailVerificationToken    String?
  emailVerificationExpires DateTime?
  resetTokenHash            String?
  resetTokenExpiry          DateTime?
  isActive                  Boolean        @default(true)
  failedLoginAttempts       Int            @default(0)
  lockoutUntil              DateTime?

  // Extended Profile
  bloodGroup                String?
  allergies                 String?
  medicalNotes              String?
  emergencyContact          String?
  emergencyPhone            String?
  emergencyRelationship     String?
  dateOfBirth               DateTime?
  gender                    String?
  address                   String?
  trekExperience            String?        @default("Beginner") // Beginner, Intermediate, Advanced
  fitnessLevel              String?        @default("Average")  // Poor, Average, Good, Excellent

  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  bookings                  Booking[]
  orders                    Order[]
  reviews                   Review[]
  blogs                     Blog[]
  memories                  Memory[]
  likes                     MemoryLike[]
  blogComments              BlogComment[]
  comments                  MemoryComment[]
  eventLeaders              EventLeader[]
  auditLogs                 AuditLog[]
  notifications             Notification[]
  sessions                  Session[]
}

// Event Types: TREK, CAMPING, NIGHT_TREK, CYCLING, BIKE_RIDE, PHOTOGRAPHY_WALK, RIVER_CROSSING, FORT_TREK, CORPORATE_EVENT
// Event Statuses: DRAFT, OPEN_REGISTRATION, REGISTRATION_CLOSED, UPCOMING, ONGOING, COMPLETED, CANCELLED
model Event {
  id             String         @id @default(uuid())
  title          String
  slug           String         @unique
  type           String         @default("TREK") // EventType values
  status         String         @default("DRAFT") // EventStatus values
  difficulty     String         // e.g. "Moderate", "Easy"
  altitude       String?        // e.g. "1646m"
  duration       String         // e.g. "2 Days"
  price          Float
  maxSeats       Int
  availableSeats Int
  waitingSeats   Int            @default(0)
  startDate      DateTime
  endDate        DateTime
  location       String
  description    String
  highlights     String         // Stringified JSON array of key highlights
  itinerary      String         // Stringified JSON structure of itinerary days/activities
  thingsToCarry  String         // Stringified JSON String array
  fitnessLevel   String
  safetyMeasures String         // Stringified JSON String array
  pickupPoints   String         // Stringified JSON String array
  images         String         // Stringified JSON String array of Cloudinary URLs
  distance       Float?         // in km
  elevationGain    Float?         // in meters
  meetingPoint     String?
  endPoint         String?
  googleMapsUrl    String?
  gpxRoute         String?        // URL to GPX file
  trekGrade        String?        // e.g. "Easy", "Moderate"
  suitableFor      String?        // e.g. "Families, Solo Travellers"
  minAge           Int            @default(10)
  latitude         Float?
  longitude        Float?
  coordinatorName  String?
  coordinatorPhone String?
  trekLeaderName   String?
  assistantLeaders String?        // Stringified JSON array of assistant leader names
  busNumber        String?        @default("Bus 1")
  pickupLocations  String?        // Stringified JSON array of pickup locations
  pickupTimings    String?        // Stringified JSON array of pickup timings
  weatherNotes     String?
  isDeleted        Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bookings       Booking[]
  reviews        Review[]
  leaders        EventLeader[]
  memories       Memory[]
  faqs           FAQ[]
  policyId       String?
  policy         TrekPolicy?    @relation(fields: [policyId], references: [id])
}

model EventLeader {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  role      String   // LeaderRole: LEADER, ASSISTANT, VOLUNTEER
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// Payment Statuses: PENDING, PAID, FAILED, REFUNDED, CANCELLED
model Booking {
  id                 String        @id @default(uuid())
  bookingId          String        @unique // e.g. TW-20260716-1234
  userId             String
  eventId            String
  totalAmount        Float
  seatCount          Int
  paymentStatus      String        @default("PENDING") // PaymentStatus values
  paymentId          String?       // Razorpay/UPI Txn ID
  razorpayOrderId    String?
  emergencyContact   String
  emergencyName      String?
  emergencyRelationship String?
  medicalDetails     String?
  waiverAccepted     Boolean       @default(false)
  waiverSignedAt     DateTime?
  termsAccepted      Boolean       @default(false)
  termsAcceptedAt    DateTime?
  ipAddress          String?
  userAgent          String?
  fitnessDeclared    Boolean       @default(false)
  riskAcknowledged   Boolean       @default(false)
  instructionsAgreed Boolean       @default(false)
  guardianPermitted  Boolean?
  couponCode         String?
  discountAmount     Float         @default(0)
  securityToken      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id])
  event              Event         @relation(fields: [eventId], references: [id])
  members            BookingMember[]
  certificate        Certificate?
}

model BookingMember {
  id                String           @id @default(uuid())
  bookingId         String
  name              String
  gender            String           @default("Male")
  age               Int
  phone             String?
  email             String?
  bloodGroup        String?
  emergencyName     String?
  emergencyPhone    String?
  medicalConditions String?
  allergies         String?
  fitnessLevel      String?          @default("Average")
  idProofType       String?
  idProofNumber     String?
  busNumber         String           @default("Bus 1")
  seatNumber        String?
  attendanceStatus  String           @default("PENDING") // AttendanceStatus values
  checkedIn         Boolean          @default(false)
  checkedInAt       DateTime?
  checkedInBy       String?
  checkedInDevice   String?
  booking           Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  checkInLogs       CheckInLog[]
}

model CheckInLog {
  id              String        @id @default(uuid())
  bookingMemberId String
  scannedAt       DateTime      @default(now())
  scannedBy       String
  deviceInfo      String?
  location        String?
  status          String        // SUCCESS, DUPLICATE, FAILED
  bookingMember   BookingMember @relation(fields: [bookingMemberId], references: [id], onDelete: Cascade)
}

model Certificate {
  id            String   @id @default(uuid())
  certificateId String   @unique // TW-CERT-XXXXX
  bookingId     String   @unique
  userId        String
  eventId       String
  pdfUrl        String   // Cloudinary URL
  createdAt     DateTime @default(now())
  booking       Booking  @relation(fields: [bookingId], references: [id])
}

model Memory {
  id         String          @id @default(uuid())
  userId     String
  eventId    String
  caption    String?
  mediaUrl   String          // Cloudinary URL
  mediaType  String          @default("IMAGE") // MediaType: IMAGE, VIDEO
  pinned     Boolean         @default(false)
  hidden     Boolean         @default(false)
  isFeatured Boolean         @default(false)
  tags       String?
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id])
  event      Event           @relation(fields: [eventId], references: [id])
  likes      MemoryLike[]
  comments   MemoryComment[]
}

model MemoryLike {
  userId    String
  memoryId  String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory    Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  @@id([userId, memoryId])
}

model MemoryComment {
  id        String   @id @default(uuid())
  userId    String
  memoryId  String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model Review {
  id                   String   @id @default(uuid())
  userId               String
  eventId              String
  rating               Int      // Overall rating
  ratingExperience     Int?     // Experience Rating (1-5)
  ratingCoordinator    Int?     // Coordinator Rating (1-5)
  ratingSafety         Int?     // Safety Rating (1-5)
  ratingFood           Int?     // Food Rating (1-5)
  ratingTransportation Int?     // Transportation Rating (1-5)
  ratingDifficulty     String?  // Difficulty rating text (Easy, Moderate, Hard)
  ratingValue          Int?     // Value for money (1-5)
  wouldRecommend       Boolean  @default(true)
  title                String?  // Review title
  comment              String   // Detailed review
  images               String   // Stringified JSON string array of review images
  isAnonymous          Boolean  @default(false)
  isVerified           Boolean  @default(true)
  replyComment         String?  // Admin response
  pinned               Boolean  @default(false)
  hidden               Boolean  @default(false)
  isApproved           Boolean  @default(false)
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id])
  event                Event    @relation(fields: [eventId], references: [id])
}

model Blog {
  id             String        @id @default(uuid())
  title          String
  slug           String        @unique
  content        String
  bannerImage    String
  category       String
  summary        String?
  readTime       String?
  isPublished    Boolean       @default(true)
  isFeatured     Boolean       @default(false)
  scheduledAt    DateTime?
  views          Int           @default(0)
  likes          Int           @default(0)
  shares         Int           @default(0)
  tags           String?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  authorId       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User          @relation(fields: [authorId], references: [id])
  versions       BlogVersion[]
  comments       BlogComment[]
}

model BlogCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogVersion {
  id          String   @id @default(uuid())
  blogId      String
  title       String
  content     String
  summary     String?
  bannerImage String?
  editedBy    String?
  createdAt   DateTime @default(now())
  blog        Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model BlogComment {
  id        String   @id @default(uuid())
  blogId    String
  userId    String
  content   String
  isPinned  Boolean  @default(false)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id        String   @id @default(uuid())
  url       String
  category  String   @default("MOUNTAINS") // MediaCategory values
  caption   String?
  createdAt DateTime @default(now())
}

model OrganizationSettings {
  id               String  @id @default(uuid())
  companyName      String  @default("TrekWari")
  founderName      String  @default("Atharva Dhawale")
  email            String  @default("atharvadhawale80@gmail.com")
  phone            String  @default("+91 9322340365")
  whatsapp         String  @default("+91 9322340365")
  instagram        String  @default("https://www.instagram.com/trekwari")
  youtube          String? @default("https://youtube.com/@trekwari")
  facebook         String? @default("https://facebook.com/trekwari")
  location         String  @default("Kopargaon, Maharashtra, India")
  logoUrl          String?
  faviconUrl       String?
  tagline          String? @default("Explore Sahyadri with Certified Leaders")
  hqName           String? @default("TrekWari HQ Basecamp")
  address          String? @default("Kopargaon Road")
  city             String? @default("Kopargaon")
  state            String? @default("Maharashtra")
  country          String? @default("India")
  pincode          String? @default("423601")
  officeTimings    String? @default("9:00 AM - 6:00 PM (Mon-Sat)")
  emergencyContact String? @default("+91 9322340365")
  googleMapsEmbed  String? @default("https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15002.570776735165!2d74.46979603099951!3d19.892403759972323!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bdd007d4b4a3a6b%3A0xe5a3c9e6db5837bd!2sKopargaon%2C%20Maharashtra%20423601!5e0!3m2!1sen!2sin!4v1700000000000!5m2!1sen!2sin")
  latitude         Float?  @default(19.892403)
  longitude        Float?  @default(74.469796)
  linkedin         String?
  twitter          String?
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discount    Float    // percentage or flat amount
  isPercentage Boolean @default(true)
  expiry      DateTime
  usageLimit  Int      @default(100)
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  eventId   String?  // Nullable means global FAQ
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String
  website   String?
  createdAt DateTime @default(now())
}

model Partner {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String
  website   String?
  createdAt DateTime @default(now())
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  image       String
  category    String      // "T-Shirts", "Caps", "Water Bottles", "Stickers", "Hoodies", "Badges"
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

// Order Statuses: PENDING, PROCESSING, SHIPPED, DELIVERED, CANCELLED
model Order {
  id            String        @id @default(uuid())
  userId        String
  totalAmount   Float
  status        String        @default("PENDING") // OrderStatus values
  paymentStatus String        @default("PENDING") // PaymentStatus values
  paymentId     String?       // UPI / Razorpay Id
  shippingAddr  String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id])
  orderItems    OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float   // Price at the time of purchase
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  action        String
  details       String
  ipAddress     String?
  previousValue String?
  newValue      String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}

model TrekPolicy {
  id                    String   @id @default(uuid())
  title                 String   @unique
  isTemplate            Boolean  @default(false)
  
  // Participant Responsibility Letter
  letterTitle           String   @default("Participant Responsibility Letter")
  letterDescription     String   @default("")
  letterTerms           String   @default("")
  letterWaiver          String   @default("")
  letterDeclaration     String   @default("")
  letterCheckboxText    String   @default("I agree to all terms and declare myself medically fit.")
  termsAndConditions    String   @default("")
  privacyPolicy         String   @default("")

  // Things to Carry & Prohibited
  thingsToCarry         String   @default("[]") // JSON: { name, isRequired, icon, order }[]
  thingsNotAllowed      String   @default("[]") // JSON: string[] or { name, description, order }[]

  // Medical requirements config
  medicalMandatoryFields String  @default("[]") // JSON: string[] e.g. ["bloodGroup", "allergies"]

  // Safety guidelines
  safetyGuidelines      String   @default("[]") // JSON: { instruction, category }[]

  // Cancellation & Refund
  cancellationRules     String   @default("[]")
  refundPercentages     String   @default("[]") // JSON: { timeframeDays, percent }[]
  weatherPolicy         String   @default("")
  organizerCancellationPolicy String @default("")
  noShowPolicy          String   @default("")

  // FAQs
  faqs                  String   @default("[]") // JSON: { question, answer }[]

  // Preparation Guide
  prepTips              String   @default("[]")
  fitnessRecommendations String  @default("[]")
  clothingSuggestions   String   @default("[]")
  foodRecommendations   String   @default("[]")
  weatherAdvice         String   @default("")
  equipmentRecommendations String @default("")

  // Downloadable Documents
  trekInfoPdf           String?
  thingsToCarryPdf      String?
  responsibilityLetterPdf String?
  safetyGuidelinesPdf   String?
  medicalDeclarationPdf String?
  cancellationPolicyPdf String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  events                Event[]
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
